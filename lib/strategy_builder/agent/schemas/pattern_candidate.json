{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "confidence", "trigger", "continuation", "invalidation"],
  "properties": {
    "name":         { "type": "string" },
    "confidence":   { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "trigger":      { "type": "string" },
    "continuation": { "type": "boolean" },
    "invalidation": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
