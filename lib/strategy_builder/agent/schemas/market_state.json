{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["instrument", "regime", "session", "bias"],
  "properties": {
    "instrument":        { "type": "string" },
    "snapshot_at":       { "type": "string" },
    "primary_timeframe": { "type": "string" },
    "regime": {
      "type": "string",
      "enum": ["trend_up", "trend_down", "range", "compression", "expansion", "chop"]
    },
    "session": {
      "type": "string",
      "enum": ["asia", "london", "ny", "asia_london_overlap", "london_ny_overlap", "closed"]
    },
    "higher_tf_bias": {
      "type": "string",
      "enum": ["bullish", "bearish", "neutral"]
    },
    "mid_tf_structure": { "type": "string" },
    "lower_tf_state":   { "type": "string" },
    "volatility": {
      "type": "string",
      "enum": ["contracting", "normal", "expanding"]
    },
    "volume": {
      "type": "string",
      "enum": ["declining", "average", "expanding"]
    },
    "bias": {
      "type": "string",
      "enum": ["long", "short", "neutral"]
    },
    "liquidity": { "type": "object" }
  }
}
