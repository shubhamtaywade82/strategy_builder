# CoinDCX API credentials (required for market data)
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# Ollama configuration
#
# --- Local (default): `ollama serve` on this machine or Docker publishing 11434 ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Must match a model your server actually has (`ollama list`). Wrong name => HTTP 404.
OLLAMA_AGENT_MODEL=llama3.1:8b
# Optional alias if you do not set OLLAMA_AGENT_MODEL:
# OLLAMA_MODEL=llama3.1:8b
#
# --- Ollama Cloud (hosted models at https://ollama.com/api) ---
# STRATEGY_BUILDER_OLLAMA_CLOUD=1
# OLLAMA_API_KEY=...   # https://ollama.com/settings/keys
# When cloud mode is on, OLLAMA_BASE_URL defaults to https://ollama.com if unset.
# OLLAMA_AGENT_MODEL=...   # use a cloud model tag from your Ollama account (often ends with -cloud)
#
# Only if you intentionally hit ollama.com without cloud mode (not recommended):
# OLLAMA_ALLOW_PUBLIC_WEBSITE=1

# Optional: agent/backtest tuning (defaults are safe)
# STRATEGY_BUILDER_PARALLEL_INSTRUMENTS=6
# STRATEGY_BUILDER_BACKTEST_WARMUP=50
# STRATEGY_BUILDER_DEFAULT_STOP_FRAC=0.01
