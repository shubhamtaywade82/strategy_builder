# CoinDCX API credentials (required for market data)
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
# Must match a model your server actually has (`ollama list`). Wrong name => HTTP 404.
OLLAMA_AGENT_MODEL=llama3.1:8b
# Optional alias if you do not set OLLAMA_AGENT_MODEL:
# OLLAMA_MODEL=llama3.1:8b

# Optional: Ollama Cloud
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=your_ollama_cloud_key
