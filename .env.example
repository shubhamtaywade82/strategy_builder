# CoinDCX API credentials (required for market data)
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# Ollama configuration
# Must be the HTTP root where `ollama serve` listens (open-source server API), NOT https://ollama.com (that is the public website, not the API).
# Same WSL2/Linux + Docker (e.g. ollama/ollama with -p 11434:11434): use http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Must match a model your server actually has (`ollama list`). Wrong name => HTTP 404.
OLLAMA_AGENT_MODEL=llama3.1:8b
# Optional alias if you do not set OLLAMA_AGENT_MODEL:
# OLLAMA_MODEL=llama3.1:8b

# Only if you intentionally proxy the API at an *ollama.com hostname (not recommended):
# OLLAMA_ALLOW_PUBLIC_WEBSITE=1
